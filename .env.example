# Copy to .env and fill with your actual keys. Do NOT commit .env.

# ========== Dune Analytics ==========
# Free key (default for routine work)
DUNE_API_KEY_FREE=

# Additional free keys for rotation (optional)
# DUNE_API_KEY_FREE_2=
# DUNE_API_KEY_FREE_3=

# Paid key (for bulk exports and enterprise features)
# DUNE_API_KEY_PAID=

# ========== Solscan Pro ==========
SOLSCAN_API_KEY=

# ========== Nansen ==========
NANSEN_API_KEY=

# Additional Nansen keys (optional, for rotation)
# NANSEN_API_KEY_2=

# ========== Solana RPC ==========
# Use one of these based on your provider
# Helius:     https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# QuickNode:  https://YOUR-NAME.solana-mainnet.quiknode.pro/YOUR-TOKEN/
# Ankr:       https://rpc.ankr.com/solana/YOUR_KEY
# Public:     https://api.mainnet-beta.solana.com    (rate-limited, not for prod)
SOLANA_RPC_URL=

# Optional: separate archive endpoint
# SOLANA_RPC_URL_ARCHIVE=

# Optional: fallback provider
# SOLANA_RPC_URL_PRIMARY=
# SOLANA_RPC_URL_FALLBACK=

# Hot wallet for trading/sniping scripts (base58 private key)
# WARNING: only use for trading, never your main wallet
# SOLANA_PRIVATE_KEY=

# ========== pump.fun (PumpPortal) ==========
# Only needed for Lightning trading endpoint (managed submission, 0.5% fee)
# Data API (WebSocket) and Local trading endpoint are free
# PUMPPORTAL_API_KEY=

# ========== Jito (optional) ==========
# UUID for higher rate limits (default free tier: 1 rps per IP per region)
# Get via Jito Discord ticket
# JITO_AUTH_UUID=

# ========== Bloxroute (optional) ==========
# BLOXROUTE_AUTH=

# ========== CoinMarketCap (planned) ==========
# CMC_API_KEY=

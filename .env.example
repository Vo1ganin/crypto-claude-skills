# Copy to .env and fill with your actual keys. Do NOT commit .env.

# ========== Dune Analytics ==========
# Free key (default for routine work)
DUNE_API_KEY_FREE=

# Additional free keys for rotation (optional)
# DUNE_API_KEY_FREE_2=
# DUNE_API_KEY_FREE_3=

# Paid key (for bulk exports and enterprise features)
# DUNE_API_KEY_PAID=

# ========== Solscan Pro ==========
SOLSCAN_API_KEY=

# ========== Nansen ==========
NANSEN_API_KEY=

# Additional Nansen keys (optional, for rotation)
# NANSEN_API_KEY_2=

# ========== Solana RPC ==========
# Use one of these based on your provider
# Helius:     https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# QuickNode:  https://YOUR-NAME.solana-mainnet.quiknode.pro/YOUR-TOKEN/
# Ankr:       https://rpc.ankr.com/solana/YOUR_KEY
# Public:     https://api.mainnet-beta.solana.com    (rate-limited, not for prod)
SOLANA_RPC_URL=

# Optional: separate archive endpoint
# SOLANA_RPC_URL_ARCHIVE=

# Optional: fallback provider
# SOLANA_RPC_URL_PRIMARY=
# SOLANA_RPC_URL_FALLBACK=
